{
    "version": 2,
    "functions": {
        "api/webhooks.js": {
            "maxDuration": 30
        },
        "api/review-jobs.js": {
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "health",
            "dest": "/api/health.js"
        },
        {
            "src": "/api/stats",
            "dest": "/api/stats.js"
        },
        {
            "src": "/api/webhooks",
            "dest": "/api/webhooks.js"
        },
        {
            "src": "/api/review-jobs",
            "dest": "/api/review-jobs.js"
        }
    ]
}